# استخدم صورة أساسية مناسبة لتطبيقك
FROM python:3.9

# قم بتثبيت أي تبعيات يحتاجها تطبيقك
RUN apt-get update && apt-get install -y bash

# انسخ ملفات مشروعك إلى داخل الصورة
COPY . /app

# حدد مجلد العمل داخل الصورة
WORKDIR /app

# حدد الأمر الذي سيتم تشغيله عند بدء تشغيل الحاوية
CMD ["bash", "start"]
